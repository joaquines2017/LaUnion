# Variables de entorno mock para vitest (RFO-002).
# No contienen secretos reales — usadas solo para que vitest pueda
# resolver process.env sin necesidad de leer el .env de producción
# (que tiene permisos 600 propiedad del usuario "launion").
DATABASE_URL="postgresql://test_user:test_pass@localhost:5432/launion_test"
AUTH_SECRET="test-secret-not-for-production-0000000000000000000000000000"
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV=test
